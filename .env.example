# Last.fm (for the music category)
# Get an API key at https://www.last.fm/api/account/create — free, instant.
LASTFM_API_KEY=

# TMDb (for movies + tv categories)
# Get a v3 API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Spotify Web API — currently dormant for new apps in 2026.
# Code is wired but Spotify restricts followers/popularity/top-tracks/previews
# for apps in Development Mode. Kept here in case you secure Extended Quota.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
