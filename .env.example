# Spotify Web API (for the music category)
# Create an app at https://developer.spotify.com/dashboard
# Uses Client Credentials flow — no user auth needed.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# TMDb (for movies + tv categories)
# Get a v3 API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
